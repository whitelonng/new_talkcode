{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-fstat",
    "fs:allow-app-meta-recursive",
    "fs:allow-write-file",
    "fs:allow-appdata-write-recursive",
    "log:default",
    {
      "identifier": "fs:scope-appdata-recursive",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:scope-home-recursive",
      "allow": [
        {
          "path": "$HOME/**"
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-resource-read-recursive",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-execute",
    "shell:allow-kill",
    "clipboard:allow-read-image-base64",
    "clipboard:allow-read-image-binary",
    "clipboard:allow-read-files",
    "clipboard:allow-read-files-uris",
    "clipboard:allow-has-image",
    "clipboard:allow-has-files",
    "clipboard:allow-read-text",
    "deep-link:default",
    "deep-link:allow-get-current",
    "deep-link:allow-is-registered",
    "deep-link:allow-register",
    "deep-link:allow-unregister",
    "core:window:allow-show",
    "core:window:allow-is-focused",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-center",
    "core:window:allow-create",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "core:window:allow-set-decorations",
    "core:window:allow-set-always-on-top",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-unminimize",
    "core:window:allow-inner-size",
    "core:window:allow-outer-size",
    "core:window:allow-outer-position",
    "core:window:allow-inner-position",
    "core:window:allow-is-visible",
    "core:window:allow-get-all-windows",
    "core:window:allow-scale-factor",
    "core:window:allow-set-fullscreen",
    "core:window:allow-internal-toggle-maximize",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "process:default",
    "process:allow-restart",
    "notification:default",
    "os:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-zsh",
          "cmd": "zsh",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-bash",
          "cmd": "bash",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-sh",
          "cmd": "sh",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-cmd",
          "cmd": "cmd",
          "args": [
            "/C",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-powershell",
          "cmd": "powershell",
          "args": [
            "-Command",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "npx",
          "cmd": "/opt/homebrew/bin/npx",
          "args": true
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": true
        },
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-zsh",
          "cmd": "zsh",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-bash",
          "cmd": "bash",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-sh",
          "cmd": "sh",
          "args": [
            "-l",
            "-c",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-cmd",
          "cmd": "cmd",
          "args": [
            "/C",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "login-shell-powershell",
          "cmd": "powershell",
          "args": [
            "-Command",
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "npx",
          "cmd": "/opt/homebrew/bin/npx",
          "args": true
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": true
        },
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": true
        }
      ]
    }
  ]
}