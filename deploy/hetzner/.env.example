# =============================================================================
# TalkCody Server Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Telegram Bot Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: restrict bot to specific Telegram users (comma-separated chat IDs)
# Leave empty to allow all users (not recommended for production)
TELEGRAM_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Host and port (usually leave as default)
HOST=0.0.0.0
PORT=8080

# Optional: API key for HTTP endpoint protection
# If set, clients must include header: X-API-Key: your_api_key
API_KEY=

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# Set at least one provider. The key name format is: PROVIDER_API_KEY_<provider_id>
# Provider IDs are typically lowercase: openai, anthropic, gemini, etc.

# OpenAI / ChatGPT
PROVIDER_API_KEY_openai=sk-...

# Anthropic / Claude
# PROVIDER_API_KEY_anthropic=sk-ant-...

# Google / Gemini
# PROVIDER_API_KEY_gemini=...

# Add more providers as needed...

# -----------------------------------------------------------------------------
# Storage Paths (Docker internal paths - usually don't change)
# -----------------------------------------------------------------------------
DATA_ROOT=/data/talkcody
WORKSPACE_ROOT=/data/workspace

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info
